# Copy to .env.local for development. In the demo these point at the real hosts.
# Tier-1 EC2 box (auth + pod lifecycle):
VITE_EC2_URL=http://localhost:9100
# Tier-2 pod (control API + audio WebSocket), fronted by Caddy TLS in the demo:
VITE_POD_URL=http://localhost:9000
# Audio WebSocket base (wss:// in the demo). Defaults to VITE_POD_URL with ws(s) scheme.
VITE_WS_URL=ws://localhost:8080
